# Kit (ConvertKit) newsletter subscription
# Get these from: https://app.kit.com → Settings → Developer → API Keys
# and: https://app.kit.com → Forms → (your form) → Settings → ID
#
# These use the PUBLIC_ prefix — they are intentionally baked into client-side
# code. Kit's public API key is designed for browser-side form subscriptions.
# Do NOT use your secret API key here.

PUBLIC_KIT_API_KEY=your_public_api_key_here
PUBLIC_KIT_FORM_ID=your_form_id_here

---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Code, Database, ChartBar, TrendingUp, GitBranch, MessageSquare, Mail, Github, Linkedin, FileText } from "@lucide/astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

type ProjectEntry = CollectionEntry<"projects">;
const allProjects: ProjectEntry[] = await getCollection("projects");
const byOrder = (a: ProjectEntry, b: ProjectEntry) =>
  (a.data.order ?? 999) - (b.data.order ?? 999);
const featured: ProjectEntry[] = allProjects
  .filter((p) => p.data.featured)
  .sort(byOrder)
  .slice(0, 4);

const skills = [
  {
    icon: Code,
    title: "Python & Data",
    desc: "Pandas, NumPy, scikit-learn, statsmodels, notebooks, Machine Learning and tuning, ETL.",
  },
  {
    icon: Database,
    title: "SQL & Warehousing",
    desc: "Modeling, queries and query development, performance, Postgres/SQLite, reporting.",
  },
  {
    icon: ChartBar,
    title: "Visualization",
    desc: "Tableau, InDesign, Figma, clear story design, accessibility and interaction.",
  },
  {
    icon: TrendingUp,
    title: "Forecasting",
    desc: "ARIMA, cross-validation, RandomForest, linear regression, evaluation/diagnostics, baselines → ML.",
  },
  {
    icon: GitBranch,
    title: "Quality & Ops",
    desc: "Version control, GitHub, CI/CD, reproducibility, documentation, lint/format.",
  },
  {
    icon: MessageSquare,
    title: "Communication",
    desc: "Executive summaries, detailed storytelling, stakeholder alignment, clear recommendations.",
  },
];

const tagColors: Record<string, string> = {
  Python: "bg-emerald-500/15 text-emerald-300 border-emerald-700/40",
  Tableau: "bg-indigo-500/15 text-indigo-300 border-indigo-700/40",
  EDA: "bg-amber-500/15 text-amber-300 border-amber-700/40",
  ARIMA: "bg-fuchsia-500/15 text-fuchsia-300 border-fuchsia-700/40",
  "Time Series": "bg-cyan-500/15 text-cyan-300 border-cyan-700/40",
  Pandas: "bg-sky-500/15 text-sky-300 border-sky-700/40",
};
const colorFor = (t: string) =>
  tagColors[t] ?? "bg-violet-500/15 text-violet-300 border-violet-700/40";

// Bar chart data: heights as percentages (0-100)
const bars = [62, 80, 48, 91, 70, 57, 84];
---

<Base
  title="Home"
  description="Portfolio of Bennett Woods — data analysis projects, skills, and contact."
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section
    id="home"
    class="flex min-h-[88vh] items-center py-16"
    aria-label="Introduction"
  >
    <div class="grid w-full gap-12 md:grid-cols-2 md:items-center">

      <!-- Left: text -->
      <div class="flex flex-col gap-6">
        <div class="reveal" style="--stagger:0">
          <p class="mb-2 text-sm font-semibold tracking-widest uppercase text-violet-400">
            Portfolio
          </p>
          <h1 class="text-6xl font-black tracking-tight leading-[1.05] text-gradient sm:text-7xl">
            Bennett<br />Woods
          </h1>
        </div>

        <div class="reveal" style="--stagger:1">
          <p class="text-xl font-medium text-zinc-400 tracking-wide">
            Data Analyst&nbsp;&bull;&nbsp;Engineer&nbsp;&bull;&nbsp;Developer
          </p>
        </div>

        <p class="text-zinc-300 leading-relaxed max-w-lg reveal" style="--stagger:2">
          Utilizing user stories, data and testing to weave customer needs
          into actionable business insights. Develop strategies to clean,
          prepare and model data using ML and AI tools.
        </p>

        <div class="flex flex-wrap gap-3 reveal" style="--stagger:3">
          <a
            href="#projects"
            class="btn-primary rounded-xl bg-violet-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-violet-500 focus-ring"
          >
            View Projects
          </a>
          <a
            href="#contact"
            class="rounded-xl border border-zinc-700 px-5 py-2.5 text-sm font-semibold text-zinc-300 hover:border-violet-500/60 hover:text-zinc-100 focus-ring transition-colors duration-150"
          >
            Contact
          </a>
        </div>
      </div>

      <!-- Right: animated bar chart -->
      <div class="flex justify-center md:justify-end reveal" style="--stagger:1" aria-hidden="true">
        <div class="relative w-full max-w-sm">
          <!-- Chart container -->
          <svg
            viewBox="0 0 320 220"
            role="presentation"
            class="w-full"
            aria-hidden="true"
          >
            <!-- Y-axis grid lines -->
            {[0.25, 0.5, 0.75].map((pct) => (
              <line
                x1="40"
                y1={20 + (1 - pct) * 160}
                x2="300"
                y2={20 + (1 - pct) * 160}
                stroke="#3f3f46"
                stroke-width="1"
                stroke-dasharray="4,4"
              />
            ))}

            <!-- Y-axis labels -->
            {[25, 50, 75].map((val) => (
              <text
                x="34"
                y={20 + (1 - val / 100) * 160 + 4}
                text-anchor="end"
                font-size="10"
                fill="#71717a"
              >
                {val}
              </text>
            ))}

            <!-- Bars -->
            {bars.map((h, i) => {
              const barH = (h / 100) * 160;
              const x = 52 + i * 36;
              return (
                <rect
                  class="chart-bar"
                  x={x}
                  y={20 + (160 - barH)}
                  width="22"
                  height={barH}
                  rx="4"
                  fill="url(#barGrad)"
                  style={`animation-delay: ${i * 100}ms`}
                />
              );
            })}

            <!-- X-axis line -->
            <line x1="40" y1="180" x2="300" y2="180" stroke="#52525b" stroke-width="1.5" />

            <!-- Gradient def -->
            <defs>
              <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgb(167 139 250)" />
                <stop offset="100%" stop-color="rgb(99 102 241)" />
              </linearGradient>
            </defs>

            <!-- Caption -->
            <text x="170" y="210" text-anchor="middle" font-size="10" fill="#52525b">
              accuracy metrics
            </text>
          </svg>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── SKILLS ───────────────────────────────────────────── -->
  <section id="skills" class="py-24" aria-labelledby="skills-heading" data-reveal-group>
    <h2 id="skills-heading" class="mb-10 text-3xl font-bold section-heading reveal">
      Skills &amp; Abilities
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {skills.map(({ icon: Icon, title, desc }) => (
        <article class="reveal card-hover rounded-2xl border border-zinc-800 bg-zinc-900 p-5">
          <div class="mb-3 text-violet-400">
            <Icon size={22} aria-hidden="true" />
          </div>
          <h3 class="mb-1.5 font-semibold text-zinc-100">{title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ─── PROJECTS ─────────────────────────────────────────── -->
  <section id="projects" class="py-24" aria-labelledby="projects-heading" data-reveal-group>
    <h2 id="projects-heading" class="mb-10 text-3xl font-bold section-heading reveal">
      Projects
    </h2>
    <div class="grid gap-5 md:grid-cols-2">
      {featured.map((p) => (
        <article class="reveal card-hover group overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900">
          <!-- Accent bar -->
          <div class="h-1 w-full bg-gradient-to-r from-violet-500 to-indigo-500" aria-hidden="true"></div>

          <div class="p-5">
            <header class="mb-2 flex items-start justify-between gap-3">
              <h3 class="text-lg font-semibold leading-snug">
                <a
                  href={`/projects/${p.slug}`}
                  class="hover:text-violet-400 focus-ring transition-colors"
                >
                  {p.data.title}
                </a>
              </h3>
              <span class="shrink-0 rounded-full border border-zinc-700 px-2 py-0.5 text-xs text-zinc-400">
                {p.data.year}
              </span>
            </header>

            <p class="mb-3 text-sm text-zinc-400 leading-relaxed">{p.data.description}</p>

            <ul class="mb-4 flex flex-wrap gap-1.5" aria-label="Tags">
              {p.data.tags?.map((t) => (
                <li class={`rounded-full border px-2 py-0.5 text-xs ${colorFor(t)}`}>{t}</li>
              ))}
            </ul>

            <div class="flex gap-4 text-sm">
              {p.data.repo && (
                <a
                  href={p.data.repo}
                  class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
                >
                  Repo
                </a>
              )}
              {p.data.demo && (
                <a
                  href={p.data.demo}
                  class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
                >
                  Live
                </a>
              )}
              <a
                href={`/projects/${p.slug}`}
                class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
              >
                Read more<span class="sr-only"> about {p.data.title}</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-8 text-sm">
      <a
        href="/projects"
        class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
      >
        See all projects &rarr;
      </a>
    </p>
  </section>

  <!-- ─── CONTACT ──────────────────────────────────────────── -->
  <section id="contact" class="py-24" aria-labelledby="contact-heading" data-reveal-group>
    <h2 id="contact-heading" class="mb-10 text-3xl font-bold section-heading reveal">
      Contact
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {[
        {
          href: "mailto:hirebennettwoods@gmail.com",
          icon: Mail,
          label: "Email",
          sub: "hirebennettwoods@gmail.com",
          external: false,
        },
        {
          href: "https://github.com/smplscrptr",
          icon: Github,
          label: "GitHub",
          sub: "github.com/smplscrptr",
          external: true,
        },
        {
          href: "https://www.linkedin.com/in/bennett-woods-173782179/",
          icon: Linkedin,
          label: "LinkedIn",
          sub: "linkedin.com/in/bennett-woods-173782179",
          external: true,
        },
        {
          href: "/BWoods_Resume_Tech.docx",
          icon: FileText,
          label: "Resume",
          sub: "Download .docx",
          external: false,
        },
      ].map(({ href, icon: Icon, label, sub, external }) => (
        <a
          href={href}
          class="reveal card-hover flex items-center gap-4 rounded-2xl border border-zinc-800 bg-zinc-900 p-5 focus-ring group"
          {...(external ? { rel: "noopener noreferrer", target: "_blank" } : {})}
        >
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-zinc-800 text-violet-400 group-hover:bg-violet-500/15 transition-colors duration-200">
            <Icon size={20} aria-hidden="true" />
          </div>
          <div>
            <p class="font-semibold text-zinc-100">{label}</p>
            <p class="text-xs text-zinc-500 truncate max-w-[180px]">{sub}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<script>
  // Progressive reveal with per-group staggering
  const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;

  if (!reduce) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("inview");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.08 }
    );

    // Stagger reveals within each labeled group
    document.querySelectorAll<HTMLElement>("[data-reveal-group]").forEach((group) => {
      group.querySelectorAll<HTMLElement>(".reveal").forEach((el, i) => {
        el.style.setProperty("--stagger", String(i));
        io.observe(el);
      });
    });

    // Standalone reveals (hero)
    document
      .querySelectorAll<HTMLElement>(".reveal:not([data-reveal-group] .reveal)")
      .forEach((el) => {
        io.observe(el);
      });
  } else {
    document.querySelectorAll(".reveal").forEach((el) => el.classList.add("inview"));
  }

  // Trigger bar chart animation when hero is visible
  const chartBars = document.querySelectorAll<HTMLElement>(".chart-bar");
  if (chartBars.length) {
    const chartIo = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            chartBars.forEach((bar) => bar.classList.add("animate"));
            chartIo.disconnect();
          }
        }
      },
      { threshold: 0.3 }
    );
    const chart = document.querySelector("svg[role='presentation']");
    if (chart) chartIo.observe(chart);
  }
</script>

---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const tagColors: Record<string, string> = {
  Python: "bg-emerald-500/15 text-emerald-300 border-emerald-700/40",
  Tableau: "bg-indigo-500/15 text-indigo-300 border-indigo-700/40",
  EDA: "bg-amber-500/15 text-amber-300 border-amber-700/40",
  ARIMA: "bg-fuchsia-500/15 text-fuchsia-300 border-fuchsia-700/40",
  "Time Series": "bg-cyan-500/15 text-cyan-300 border-cyan-700/40",
  Pandas: "bg-sky-500/15 text-sky-300 border-sky-700/40",
};
const colorFor = (t: string) =>
  tagColors[t] ?? "bg-violet-500/15 text-violet-300 border-violet-700/40";

type ProjectEntry = CollectionEntry<"projects">;
const all: ProjectEntry[] = await getCollection("projects");

const tagSet = new Set<string>();
for (const p of all) for (const t of p.data.tags ?? []) tagSet.add(t);
const allTags = Array.from(tagSet).sort((a, b) => a.localeCompare(b));

const url = Astro.url;
const selectedParam = url.searchParams.get("tags") ?? "";
const selectedTags = selectedParam
  .split(",")
  .map((s) => s.trim())
  .filter(Boolean);

const byOrder = (a: ProjectEntry, b: ProjectEntry) =>
  (a.data.order ?? 999) - (b.data.order ?? 999);

const visible = all
  .slice()
  .sort(byOrder)
  .filter((p) =>
    selectedTags.length === 0
      ? true
      : (p.data.tags ?? []).some((t) => selectedTags.includes(t))
  )
  .map((p) => ({ slug: p.slug, ...p.data }));

function toggleTag(tag: string) {
  const set = new Set(selectedTags);
  if (set.has(tag)) set.delete(tag);
  else set.add(tag);
  return Array.from(set).join(",");
}

const chipLinks = Object.fromEntries(
  allTags.map((t) => [
    t,
    `/projects${toggleTag(t) ? `?tags=${toggleTag(t)}` : ""}`,
  ])
);
---

<Base
  title="Projects"
  description="Projects by Bennett Woods — data analysis, engineering, and development."
>
  <Fragment slot="header"><Header /></Fragment>

  <div class="py-16">
    <header class="mb-10">
      <a
        href="/"
        class="mb-6 inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-violet-400 focus-ring transition-colors"
      >
        &larr; Home
      </a>
      <h1 class="text-4xl font-black text-zinc-100 section-heading">All Projects</h1>
    </header>

    <!-- Tag filter chips -->
    <div class="mb-8 flex flex-wrap gap-2" role="group" aria-label="Filter projects by tag">
      <a
        href="/projects"
        class={`inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium focus-ring transition-colors
          ${selectedTags.length === 0
            ? "bg-violet-600 text-white border-violet-600"
            : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-violet-500/50 hover:text-zinc-200"}`}
      >
        All
      </a>

      {allTags.map((t) => (
        <a
          href={chipLinks[t]}
          class={`inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium focus-ring transition-colors
            ${selectedTags.includes(t)
              ? "bg-violet-600 text-white border-violet-600"
              : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-violet-500/50 hover:text-zinc-200"}`}
        >
          {t}
        </a>
      ))}
    </div>

    {selectedTags.length > 0 && (
      <p class="mb-6 text-sm text-zinc-500">
        Showing projects tagged with:{" "}
        <strong class="text-zinc-300">{selectedTags.join(", ")}</strong>
        {" — "}
        <a class="text-violet-400 hover:underline focus-ring" href="/projects">clear filter</a>
      </p>
    )}

    {visible.length === 0 ? (
      <div class="mt-8 rounded-2xl border border-dashed border-zinc-700 p-10 text-center">
        <p class="text-zinc-500">No projects match those tags.</p>
        <a
          href="/projects"
          class="mt-3 inline-block text-sm text-violet-400 hover:underline focus-ring"
        >
          Clear filters
        </a>
      </div>
    ) : (
      <div class="grid gap-5 md:grid-cols-2">
        {visible.map((p) => (
          <article class="card-hover group overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900">
            <!-- Accent bar -->
            <div class="h-1 w-full bg-gradient-to-r from-violet-500 to-indigo-500" aria-hidden="true"></div>

            <div class="p-5">
              <header class="mb-2 flex items-start justify-between gap-3">
                <h2 class="text-lg font-semibold leading-snug">
                  <a
                    href={`/projects/${p.slug}`}
                    class="hover:text-violet-400 focus-ring transition-colors"
                  >
                    {p.title}
                  </a>
                </h2>
                <span class="shrink-0 rounded-full border border-zinc-700 px-2 py-0.5 text-xs text-zinc-400">
                  {p.year}
                </span>
              </header>

              <p class="mb-3 text-sm text-zinc-400 leading-relaxed">{p.description}</p>

              <ul class="mb-4 flex flex-wrap gap-1.5" aria-label="Tags">
                {p.tags?.map((t) => (
                  <li class={`rounded-full border px-2 py-0.5 text-xs ${colorFor(t)}`}>{t}</li>
                ))}
              </ul>

              <div class="flex gap-4 text-sm">
                {p.repo && (
                  <a
                    href={p.repo}
                    class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
                  >
                    Repo
                  </a>
                )}
                {p.demo && (
                  <a
                    href={p.demo}
                    class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
                  >
                    Live
                  </a>
                )}
                <a
                  href={`/projects/${p.slug}`}
                  class="text-zinc-400 hover:text-violet-400 underline decoration-dotted hover:decoration-solid focus-ring transition-colors"
                >
                  Read more<span class="sr-only"> about {p.title}</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
